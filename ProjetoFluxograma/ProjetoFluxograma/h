 private void btnResultado_Click(object sender, EventArgs e)
        {
            double produto = double.Parse(txtresultado.Text);
            double resultado;
            resultado = Math.Sqrt(produto);
            MessageBox.Show("A raiz quadrada é: " + resultado);



        }